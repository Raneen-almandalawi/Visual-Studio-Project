@page
@model IndexModel
@{
    ViewData["Title"] = "Raneen Almandalawi - Music Showcase";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>

    <style>
            body {
                background: radial-gradient(circle at top, #2b1055, #000000);
                color: #f5f5f5;
                font-family: "Segoe UI", sans-serif;
                margin: 0;
                padding: 0;
                text-align: center;
            }

            h1 {
                margin-top: 40px;
                font-size: 3.2rem;
                font-weight: 800;
                letter-spacing: 4px;
                color: #ffffff;
                text-shadow: 0 0 15px #ff66c4;
            }

            .video-wrapper {
                margin-top: 50px;
                display: flex;
                justify-content: center;
            }

            iframe {
                border-radius: 14px;
                box-shadow: 0 0 25px rgba(255, 102, 196, 0.4);
            }

            footer {
                margin-top: 60px;
                padding: 20px;
                font-size: 1rem;
                opacity: 0.75;
            }
    </style>
</head>

<body>

    <h1 id="mainTitle">Welcome, Raneen Almandalawi</h1>

    <div class="video-wrapper">
        <!-- Replace with your favorite song -->
        <iframe width="800" height="450"
                src="https://www.youtube.com/embed/3AtDnEC4zak"
                title="Music Video"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen>
        </iframe>
    </div>

    <footer>
        © @DateTime.Now.Year — Designed uniquely for <strong>Raneen Almandalawi</strong>
    </footer>

    <script>
            // Animated color-shift effect for the H1
            const title = document.getElementById("mainTitle");
            let hue = 0;

            function animate() {
                hue = (hue + 2) % 360;
                title.style.color = `hsl(${hue}, 90%, 70%)`;
                title.style.textShadow = `0 0 25px hsl(${(hue + 120) % 360}, 90%, 60%)`;
                requestAnimationFrame(animate);
            }

            animate();
    </script>

</body>
</html>
